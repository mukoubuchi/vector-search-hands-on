# Milvus connection settings (instructor - local Docker environment)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=Milvus

# Embedding model settings (Hugging Face Transformers)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# Collection settings
COLLECTION_NAME=knowledge_base

# How to use:
# 1. Copy this file to .env
# 2. Keep MILVUS_HOST=localhost for the local Docker environment
# 3. Reload IBM Bob

# Recommended models:
# - paraphrase-multilingual-MiniLM-L12-v2 (384 dim, multilingual, recommended)
# - all-MiniLM-L6-v2 (384 dim, English only, faster)
# - intfloat/multilingual-e5-base (768 dim, high quality, multilingual)
