# Milvus 接続情報（講師用 - ローカルDocker環境）
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=Milvus

# Embedding モデル設定（Hugging Face Transformers）
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# コレクション設定
COLLECTION_NAME=knowledge_base

# 使用方法:
# 1. このファイルを .env にコピー
# 2. 環境に応じて MILVUS_HOST を設定
#    - ローカルDocker: localhost
#    - watsonx.data: Proxy hostの値
# 3. IBM Bob をリロード

# 推奨モデル:
# - paraphrase-multilingual-MiniLM-L12-v2 (384次元, 多言語対応, 推奨)
# - all-MiniLM-L6-v2 (384次元, 英語のみ, 高速)
# - intfloat/multilingual-e5-base (768次元, 高品質, 多言語)