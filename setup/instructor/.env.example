# Milvus connection settings (instructor - local Docker environment)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=root
# Generated automatically by start-all.sh on first start (leave empty here).
# Share this value with participants instead of the old "Milvus" default.
MILVUS_PASSWORD=

# MinIO credentials (internal to the Milvus stack; bound to 127.0.0.1)
# MINIO_ROOT_PASSWORD is generated automatically by start-all.sh.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=

# Embedding model settings (Hugging Face Transformers)
# The vector dimension is detected automatically from the model
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Collection settings (use your own unique name when testing participant scripts)
COLLECTION_NAME=products_instructor

# How to use:
# 1. You normally do NOT need to copy this file: ./start-all.sh creates and
#    updates setup/instructor/.env with generated passwords automatically.
# 2. Copy this file to .env only if you want to pre-seed values by hand.
# 3. docker compose reads MINIO_* values from .env; the participant-style
#    scripts read MILVUS_* values when run with this directory's .env.

# Recommended models:
# - paraphrase-multilingual-MiniLM-L12-v2 (384 dim, multilingual, recommended)
# - all-MiniLM-L6-v2 (384 dim, English only, faster)
# - intfloat/multilingual-e5-base (768 dim, high quality, multilingual)
