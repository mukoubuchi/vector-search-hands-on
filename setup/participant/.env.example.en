# Milvus connection settings (replace with information provided by the instructor)
MILVUS_HOST=<instructor-ip-address>  # e.g. 192.168.1.100
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=Milvus

# Embedding model settings (Hugging Face Transformers)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# Collection settings
COLLECTION_NAME=knowledge_base

# Participant language (en or ja)
PARTICIPANT_LANGUAGE=en

# How to use:
# 1. Copy this file to .env
# 2. Update connection settings with the values provided by the instructor
#    - On-site (same network): change MILVUS_HOST to the IP address (e.g. 192.168.1.100)
#    - Remote (ngrok): change MILVUS_HOST to the hostname AND MILVUS_PORT to the assigned port
#      e.g. MILVUS_HOST=0.tcp.jp.ngrok.io / MILVUS_PORT=24051
# 3. Reload IBM Bob (Cmd+Shift+P -> "Reload Window")

# Recommended models:
# - paraphrase-multilingual-MiniLM-L12-v2 (384 dim, multilingual, recommended)
# - all-MiniLM-L6-v2 (384 dim, English only, faster)
# - intfloat/multilingual-e5-base (768 dim, high quality, multilingual)
