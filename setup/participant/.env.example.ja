# Milvus 接続設定（講師から配布された情報に置き換えてください）
MILVUS_HOST=<講師から配布されたIPアドレス>  # 例: 192.168.1.100
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=Milvus

# 埋め込みモデル設定（Hugging Face Transformers）
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# コレクション設定
COLLECTION_NAME=knowledge_base

# 受講言語（en または ja）
PARTICIPANT_LANGUAGE=ja

# 使い方:
# 1. このファイルを .env にコピーします
# 2. 講師から配布された接続情報に合わせて変更します
#    - 同一ネットワーク（会場内）: MILVUS_HOST を IP アドレスに変更（例: 192.168.1.100）
#    - リモート（ngrok）: MILVUS_HOST をホスト名に、MILVUS_PORT を配布されたポート番号に変更
#      例) MILVUS_HOST=0.tcp.jp.ngrok.io / MILVUS_PORT=24051
# 3. IBM Bob を再読み込みします（Cmd+Shift+P -> "Reload Window"）

# 推奨モデル:
# - paraphrase-multilingual-MiniLM-L12-v2（384 次元、多言語対応、推奨）
# - all-MiniLM-L6-v2（384 次元、英語のみ、高速）
# - intfloat/multilingual-e5-base（768 次元、高品質、多言語対応）
