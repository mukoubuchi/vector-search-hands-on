                <!-- Key Point -->
                <mxCell id="keypoint" value="<b>ポイント</b><br>・意味が似ていると、ベクトルも似る<br>・コンピュータは数値の類似度を高速計算" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;" vertex="1" parent="1">
