                </mxCell>
                <mxCell id="user-input" value="<b>ユーザー入力</b><br>「赤いスニーカー」" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;strokeWidth=2;" vertex="1" parent="step1-box">
