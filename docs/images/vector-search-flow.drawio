                <mxCell id="arrow4" value="類似ベクトル" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=3;strokeColor=#388E3C;fontColor=#388E3C;fontStyle=1;fontSize=12;" edge="1" parent="1" source="milvus" target="results">
