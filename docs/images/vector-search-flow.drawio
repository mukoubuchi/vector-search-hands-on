                </mxCell>
                <mxCell id="embedding" value="<b>埋め込みモデル</b><br>テキスト → ベクトル" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#F57C00;strokeWidth=2;" vertex="1" parent="step2-box">
                    <mxGeometry x="30" y="45" width="220" height="55" as="geometry"/>
                </mxCell>

                <!-- Step 3 Container -->
                <mxCell id="step3-box" value="<b>ステップ 3: ベクトル表現</b>" style="swimlane;startSize=30;fillColor=#F3E5F5;strokeColor=#7B1FA2;html=1;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="760" y="100" width="360" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="vector" value="<b>ベクトル（384次元）</b><br>[0.2, 0.8, 0.1, 0.5, ...]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;strokeWidth=2;" vertex="1" parent="step3-box">
