                <!-- Step 4 Container -->
                <mxCell id="step4-box" value="<b>ステップ 4: 類似検索</b>" style="swimlane;startSize=30;fillColor=#E8F5E9;strokeColor=#388E3C;html=1;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="760" y="280" width="360" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="milvus" value="<b>Milvus</b><br>ベクトルデータベース" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;strokeWidth=2;size=15;" vertex="1" parent="step4-box">
                    <mxGeometry x="120" y="45" width="120" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="data-note" value="<b>保存済み</b><br>商品データ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#388E3C;dashed=1;strokeWidth=2;" vertex="1" parent="step4-box">
