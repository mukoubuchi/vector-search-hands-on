                <mxCell id="step1-box" value="<b>ステップ 1: テキスト入力</b>" style="swimlane;startSize=30;fillColor=#E3F2FD;strokeColor=#1976D2;html=1;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
