                </mxCell>
                <mxCell id="results" value="<b>類似商品リスト（類似度スコア付き）</b><br>・赤いランニングシューズ (0.92)<br>・レッドスポーツシューズ (0.88)<br>・赤色スニーカー (0.85)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#C2185B;strokeWidth=2;align=left;" vertex="1" parent="step5-box">
