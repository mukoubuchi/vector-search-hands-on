                </mxCell>

                <!-- Step 2 Container -->
                <mxCell id="step2-box" value="<b>ステップ 2: ベクトル変換</b>" style="swimlane;startSize=30;fillColor=#FFF3E0;strokeColor=#F57C00;html=1;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
